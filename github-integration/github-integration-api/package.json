{
  "name": "github-integration-api",
  "version": "1.0.0",
  "description": "Node.js v22 + ExpressJS + MongoDB backend for GitHub integration",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "debug": "set ENV_NAME=localhost&& nodemon --exec node --inspect=0.0.0.0:9229 --require ts-node/register ./index.ts"
  },
  "type": "commonjs",
  "keywords": [
    "node",
    "express",
    "mongodb",
    "github",
    "integration",
    "typescript"
  ],
  "author": "Your Name",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.5.0",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "mongoose": "^7.3.1",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.4",
    "@types/node": "^20.6.1",
    "@types/cors": "^2.8.19",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.2"
  }
}
